# Copy this to .env and fill it in.
# Load it with (Node 20.6+), from an agent directory:
#   node --env-file=../.env agent.js
OPENAI_API_KEY=sk-...
# Optional: override the (outer) model (default: gpt-5.5)
# OPENAI_MODEL=gpt-5.5
# Optional, trace agents only: model for the trace emulation calls
# OPENAI_TRACE_MODEL=gpt-5.5
